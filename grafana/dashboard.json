    "panel-4": {
      "kind": "Panel",
      "spec": {
        "data": {
          "kind": "QueryGroup",
          "spec": {
            "queries": [
              {
                "kind": "PanelQuery",
                "spec": {
                  "hidden": false,
                  "query": {
                    "datasource": {
                      "name": "cfjoy0x6ljf28e"
                    },
                    "group": "grafana-postgresql-datasource",
                    "kind": "DataQuery",
                    "spec": {
                      "dataset": "postgres",
                      "editorMode": "code",
                      "format": "time_series",
                      "rawSql": "SELECT date_trunc('minute', criado_em) AS time, AVG(tempo_resposta_segundos) AS \"Tempo Médio (s)\" FROM jarvis_respostas WHERE $__timeFilter(criado_em) GROUP BY 1 ORDER BY 1"
                    },
                    "version": "v0"
                  },
                  "refId": "A"
                }
              }
            ],
            "queryOptions": {},
            "transformations": []
          }
        },
