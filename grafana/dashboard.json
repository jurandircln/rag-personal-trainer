{
  "__inputs": [
    {
      "name": "DS_POSTGRESQL",
      "label": "PostgreSQL (Supabase)",
      "description": "Conexão PostgreSQL com o banco Supabase do Jarvis",
      "type": "datasource",
      "pluginId": "postgres",
      "pluginName": "PostgreSQL"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "postgres",
      "name": "PostgreSQL",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    }
  ],
  "annotations": {
    "list": []
  },
  "description": "Observabilidade do Jarvis — métricas de desempenho do LLM",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value"
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS value FROM jarvis_respostas",
          "refId": "A"
        }
      ],
      "title": "Total de Perguntas Respondidas",
      "type": "stat"
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value"
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS value FROM jarvis_feedbacks",
          "refId": "A"
        }
      ],
      "title": "Feedbacks Preenchidos pelos Usuários",
      "type": "stat"
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "decimals": 3,
          "mappings": [],
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.8 }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value"
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
          "format": "table",
          "rawSql": "SELECT ROUND(AVG(satisfeito::int)::numeric, 3) AS value FROM jarvis_feedbacks",
          "refId": "A"
        }
      ],
      "title": "Taxa de Satisfação dos Usuários com o LLM",
      "type": "stat"
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "segundos",
            "axisPlacement": "auto",
            "fillOpacity": 20,
            "gradientMode": "none",
            "lineWidth": 2,
            "showPoints": "auto",
            "spanNulls": false
          },
          "mappings": [],
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "id": 4,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
          "format": "time_series",
          "rawSql": "SELECT date_trunc('minute', criado_em) AS time, AVG(tempo_resposta_segundos) AS \"Tempo Médio (s)\" FROM jarvis_respostas WHERE $__timeFilter(criado_em) GROUP BY 1 ORDER BY 1",
          "refId": "A"
        }
      ],
      "title": "Tempo de Resposta do LLM",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisPlacement": "auto",
            "fillOpacity": 0,
            "gradientMode": "none",
            "lineWidth": 2,
            "showPoints": "auto",
            "spanNulls": false
          },
          "mappings": [],
          "max": 1,
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "id": 5,
      "options": {
        "legend": { "calcs": ["mean"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
          "format": "time_series",
          "rawSql": "SELECT date_trunc('hour', criado_em) AS time, ROUND(AVG(satisfeito::int)::numeric, 3) AS \"Taxa de Satisfação\" FROM jarvis_feedbacks WHERE $__timeFilter(criado_em) GROUP BY 1 ORDER BY 1",
          "refId": "A"
        },
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
          "format": "time_series",
          "rawSql": "SELECT date_trunc('hour', r.criado_em) AS time, ROUND(COUNT(f.id)::numeric / NULLIF(COUNT(r.id), 0), 3) AS \"Proporção c/ Feedback\" FROM jarvis_respostas r LEFT JOIN jarvis_feedbacks f ON date_trunc('hour', f.criado_em) = date_trunc('hour', r.criado_em) WHERE $__timeFilter(r.criado_em) GROUP BY 1 ORDER BY 1",
          "refId": "B"
        },
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
          "format": "time_series",
          "rawSql": "SELECT date_trunc('hour', criado_em) AS time, ROUND(LEAST(1.0 / NULLIF(AVG(tempo_resposta_segundos), 0) / 2.0, 1.0)::numeric, 3) AS \"Velocidade Normalizada\" FROM jarvis_respostas WHERE $__timeFilter(criado_em) GROUP BY 1 ORDER BY 1",
          "refId": "C"
        }
      ],
      "title": "Score de Performance do LLM",
      "type": "timeseries"
    }
  ],
  "refresh": "5s",
  "schemaVersion": 38,
  "tags": ["jarvis", "llm", "observabilidade"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Jarvis — Desempenho do LLM",
  "uid": "jarvis-llm-performance",
  "version": 1
}
